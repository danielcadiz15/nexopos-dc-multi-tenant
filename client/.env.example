# Copiar a .env.local (no commitear). URL HTTPS del APK para el botón del login.
# REACT_APP_CAJA_APK_URL=

# URL pública del front (Firebase usa esto como “continuar” tras verificar correo).
# Debe estar en Authorized domains del proyecto en Firebase Console.
# REACT_APP_PUBLIC_APP_URL=https://nexopos-dc.web.app
