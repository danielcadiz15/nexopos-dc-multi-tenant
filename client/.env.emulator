# Solo variables públicas (orientación al emulador). Cargado con: npm run start:emu
# full = Auth+Firestore+Functions emuladores (requiere Java y npm run emulators).
# api-only = solo Functions emuladas; Auth/Firestore reales — útil si falta JDK.
REACT_APP_USE_EMULATORS=true
REACT_APP_EMULATORS_MODE=full
REACT_APP_PUBLIC_APP_URL=http://localhost:3000
REACT_APP_FIREBASE_FUNCTIONS_URL=http://127.0.0.1:5001/nexopos-dc/us-central1/api
